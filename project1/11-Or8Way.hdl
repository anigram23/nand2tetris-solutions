/**
 * 8-way Or gate: 
 * out = in[0] Or in[1] Or ... Or in[7]
 */
CHIP Or8Way {
    IN in[8];
    OUT out;

    PARTS:
    //// Replace this comment with your code.
    Or(a=in[0], b=in[1], out=b1);
    Or(a=b1, b=in[2], out=b2);
    Or(a=b2, b=in[3], out=b3);
    Or(a=b3, b=in[4], out=b4);
    Or(a=b4, b=in[5], out=b5);
    Or(a=b5, b=in[6], out=b6);
    Or(a=b6, b=in[7], out=out);
}