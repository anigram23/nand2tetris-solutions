/** 
 * Multiplexor:
 * if (sel = 0) out = a, else out = b
 */
CHIP Mux {
    IN a, b, sel;
    OUT out;

    PARTS:
        Not(in=a, out=nota);
        Not(in=b, out=notb);
        Not(in=sel, out=notsel);
        And(a=a, b=b, out=c1);
        And(a=nota, b=b, out=c2);
        And(a=a, b=notb, out=c3);
        And(a=c2, b=sel, out=c4);
        And(a=c3, b=notsel, out=c5);
        Or(a=c4, b=c5, out=c6);
        Or(a=c6, b=c1, out=out); 
}